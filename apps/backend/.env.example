# ─────────────────────────────────────────────────────────────────
# NEXUS Portfolio Backend — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# .env is gitignored. Never commit real secrets.
# ─────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins.
# Include your frontend dev server and deployed frontend URL.
CORS_ORIGINS=["http://localhost:5173"]

# ── Database (optional) ───────────────────────────────────────────
# PostgreSQL connection string with pgvector extension.
# When set, the RAG service uses vector search and the contact form
# persists submissions to the contact_submissions table.
# When not set, the service falls back to local keyword retrieval
# and the contact form returns direct-contact fallback info.
#
# Example: postgresql://user:password@host:5432/nexus_db
DATABASE_URL=

# ── Contact form fallback ─────────────────────────────────────────
# Shown to users when the database is unavailable so submissions
# are never silently discarded. Set to your real contact email.
CONTACT_EMAIL=

# ── Gemini (priority 1 — used for chat if GEMINI_API_KEY is set) ─
# Get your key from https://aistudio.google.com/app/apikey
# When set, Gemini is used for chat generation instead of OpenAI.
# OpenAI is still used for embeddings if DATABASE_URL is also set.
GEMINI_API_KEY=google_api_key_here

# Gemini chat model. Default: gemini-2.5-flash
GEMINI_CHAT_MODEL=gemini-2.5-flash

# Gemini API base URL. Override only if proxying.
# Default: https://generativelanguage.googleapis.com/v1beta
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ── OpenAI (priority 2 for chat; also used for embeddings) ────────
# When set and GEMINI_API_KEY is not set, OpenAI is used for chat.
# When DATABASE_URL is also set, OpenAI embeddings power pgvector retrieval.
OPENAI_API_KEY=

# OpenAI API base URL. Override to use Azure OpenAI or a compatible proxy.
# Default: https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Chat model to use.
# Default: gpt-4o-mini
OPENAI_CHAT_MODEL=gpt-4o-mini

# Embedding model. Must match the dimensions below.
# Default: text-embedding-3-small
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Embedding vector dimensions. Must match the model above.
# Default: 1536
EMBEDDING_DIMENSIONS=1536

# Number of top chunks returned by vector search.
# Default: 5
RAG_TOP_K=5
