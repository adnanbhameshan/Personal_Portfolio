# ─────────────────────────────────────────────────────────────────
# NEXUS Portfolio Frontend — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# .env is gitignored. Never commit real secrets.
# ─────────────────────────────────────────────────────────────────

# Backend API URL.
# Development default: http://localhost:8000
# Set to your deployed backend URL in production.
VITE_API_URL=http://localhost:8000

# Resume PDF URL.
# Leave empty to show "Resume available upon request" on the Resume page.
# Set to a direct URL to a hosted PDF to enable the download button.
# Example: https://your-storage.com/adnan-resume.pdf
VITE_RESUME_URL=
